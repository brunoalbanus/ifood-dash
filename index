<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dashboard iFood — Drogarias Venancio</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=DM+Mono:wght@400;500&display=swap');
:root {
  --bg:#0d0f14; --surface:#14171f; --surface2:#1c2030; --border:#252a38;
  --accent:#ff3e6c; --accent2:#ff8c42; --green:#00d9a0; --yellow:#ffd60a;
  --blue:#4a90f5; --text:#e8eaf0; --text2:#8890a8; --text3:#4a5068;
  --red:#ff4757; --font:'Space Grotesk',sans-serif; --mono:'DM Mono',monospace;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{background:var(--bg);color:var(--text);font-family:var(--font);min-height:100vh;}

/* HEADER */
.header{background:linear-gradient(135deg,#0d0f14 0%,#1a0a20 50%,#0d1420 100%);border-bottom:1px solid var(--border);padding:20px 28px;display:flex;align-items:center;gap:16px;position:sticky;top:0;z-index:100;backdrop-filter:blur(10px);}
.logo{width:44px;height:44px;background:var(--accent);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;}
.header h1{font-size:17px;font-weight:600;}
.header p{font-size:12px;color:var(--text2);margin-top:2px;}
.header-right{margin-left:auto;display:flex;gap:8px;align-items:center;flex-wrap:wrap;}

/* FILTER BAR */
.filter-bar{background:var(--surface);border-bottom:1px solid var(--border);padding:12px 28px;display:flex;gap:10px;align-items:center;flex-wrap:wrap;}
.filter-label{font-size:11px;color:var(--text2);text-transform:uppercase;letter-spacing:.6px;flex-shrink:0;}
.filter-chip{padding:6px 14px;border-radius:20px;font-size:12px;font-weight:500;background:var(--surface2);border:1px solid var(--border);color:var(--text2);cursor:pointer;transition:all .2s;white-space:nowrap;}
.filter-chip:hover{border-color:var(--blue);color:var(--text);}
.filter-chip.active{background:var(--blue);border-color:var(--blue);color:white;}
.filter-divider{width:1px;height:20px;background:var(--border);margin:0 4px;}

/* NAV */
.nav-tabs{display:flex;gap:2px;padding:14px 28px 0;border-bottom:1px solid var(--border);background:var(--surface);overflow-x:auto;}
.tab{padding:10px 18px;cursor:pointer;font-size:13px;font-weight:500;color:var(--text2);border-bottom:2px solid transparent;white-space:nowrap;transition:all .2s;}
.tab:hover{color:var(--text);}
.tab.active{color:var(--accent);border-bottom-color:var(--accent);}

/* CONTENT */
.content{padding:22px 28px;max-width:1600px;}
.section{display:none;}
.section.active{display:block;}

/* KPI */
.kpi-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(170px,1fr));gap:14px;margin-bottom:24px;}
.kpi{background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:18px;position:relative;overflow:hidden;transition:transform .2s;}
.kpi:hover{transform:translateY(-2px);}
.kpi::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;}
.kpi.sla::before{background:var(--blue);}
.kpi.nsu::before{background:var(--green);}
.kpi.ruptura::before{background:var(--yellow);}
.kpi.cancel::before{background:var(--accent);}
.kpi.atraso::before{background:var(--accent2);}
.kpi.tempo::before{background:#a78bfa;}
.kpi.pedidos::before{background:#64748b;}
.kpi-label{font-size:10px;color:var(--text2);text-transform:uppercase;letter-spacing:.7px;margin-bottom:6px;}
.kpi-value{font-size:26px;font-weight:700;font-family:var(--mono);}
.kpi-sub{font-size:10px;color:var(--text3);margin-top:3px;}
.kpi-delta{font-size:11px;margin-top:5px;font-weight:500;}
.up{color:var(--green);}
.down{color:var(--red);}

/* BENCH */
.bench-wrap{background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:20px;margin-bottom:24px;}
.bench-chart{display:flex;gap:12px;margin-top:16px;overflow-x:auto;}
.bench-week{flex:1;min-width:150px;background:var(--surface2);border-radius:10px;padding:14px;}
.bench-week-label{font-size:11px;color:var(--text2);margin-bottom:12px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.bench-metric{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;}
.bench-metric-name{font-size:11px;color:var(--text2);}
.bench-metric-val{font-family:var(--mono);font-size:12px;font-weight:600;}

/* SEC HEADER */
.sec-header{display:flex;align-items:center;gap:10px;margin-bottom:16px;}
.sec-header h2{font-size:15px;font-weight:600;}
.chip{padding:3px 10px;background:var(--surface2);border-radius:20px;font-size:11px;color:var(--text2);}
.sec-divider{height:1px;background:var(--border);margin:28px 0;}

/* TOP GRIDS */
.top-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:16px;margin-bottom:24px;}
.top-card{background:var(--surface);border:1px solid var(--border);border-radius:14px;overflow:hidden;}
.top-card-header{padding:14px 18px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px;}
.top-card-header .icon{font-size:18px;}
.top-card-header h3{font-size:13px;font-weight:600;}
.top-card-header .subtitle{font-size:11px;color:var(--text2);margin-top:1px;}
.top-item{display:flex;align-items:center;padding:10px 18px;border-bottom:1px solid var(--border);}
.top-item:last-child{border-bottom:none;}
.top-rank{width:22px;height:22px;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;margin-right:10px;flex-shrink:0;}
.top-store{flex:1;min-width:0;}
.top-store-name{font-size:12px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.top-store-city{font-size:10px;color:var(--text2);margin-top:1px;}
.top-val{font-family:var(--mono);font-size:13px;font-weight:600;margin-left:10px;flex-shrink:0;}

/* TABLE */
.table-wrap{background:var(--surface);border:1px solid var(--border);border-radius:14px;overflow:hidden;}
.table-controls{display:flex;gap:10px;padding:14px 18px;border-bottom:1px solid var(--border);flex-wrap:wrap;align-items:center;}
.search-box{flex:1;min-width:180px;background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:7px 12px;color:var(--text);font-size:13px;font-family:var(--font);outline:none;}
.search-box:focus{border-color:var(--accent);}
.search-box::placeholder{color:var(--text3);}
.sort-btn{padding:7px 12px;background:var(--surface2);border:1px solid var(--border);border-radius:8px;color:var(--text2);font-size:11px;cursor:pointer;font-family:var(--font);transition:all .2s;white-space:nowrap;}
.sort-btn.active,.sort-btn:hover{background:var(--accent);border-color:var(--accent);color:white;}
table{width:100%;border-collapse:collapse;}
thead th{padding:10px 12px;text-align:left;font-size:10px;color:var(--text2);text-transform:uppercase;letter-spacing:.5px;border-bottom:1px solid var(--border);white-space:nowrap;}
tbody tr{border-bottom:1px solid var(--border);transition:background .15s;cursor:pointer;}
tbody tr:last-child{border-bottom:none;}
tbody tr:hover{background:var(--surface2);}
td{padding:10px 12px;font-size:12px;}
.td-store{font-weight:500;max-width:200px;}
.td-store small{display:block;font-size:10px;color:var(--text2);margin-top:1px;font-weight:400;}
.td-regional{display:inline-flex;align-items:center;padding:2px 8px;border-radius:10px;font-size:10px;font-weight:600;white-space:nowrap;}
.bar-cell{display:flex;align-items:center;gap:6px;}
.bar{height:4px;border-radius:2px;flex-shrink:0;}
.pct{font-family:var(--mono);font-size:12px;white-space:nowrap;}
.spark{display:inline-flex;align-items:flex-end;gap:2px;height:22px;}
.spark-bar{width:5px;border-radius:2px 2px 0 0;}
.trend-up{color:var(--green);}
.trend-down{color:var(--red);}
.trend-flat{color:var(--text3);}
.score-badge{display:inline-flex;align-items:center;justify-content:center;width:40px;height:20px;border-radius:6px;font-size:10px;font-weight:700;font-family:var(--mono);}
.score-high{background:rgba(255,71,87,.15);color:var(--red);}
.score-med{background:rgba(255,214,10,.12);color:var(--yellow);}
.score-low{background:rgba(0,217,160,.12);color:var(--green);}

/* PAGINATION */
.pagination{display:flex;align-items:center;justify-content:space-between;padding:12px 18px;border-top:1px solid var(--border);}
.page-info{font-size:11px;color:var(--text2);}
.page-btns{display:flex;gap:6px;}
.page-btn{padding:5px 12px;background:var(--surface2);border:1px solid var(--border);border-radius:6px;cursor:pointer;font-size:11px;color:var(--text2);font-family:var(--font);transition:all .2s;}
.page-btn:hover,.page-btn.active{background:var(--accent);border-color:var(--accent);color:white;}
.page-btn:disabled{opacity:.3;cursor:default;}

/* TREND ITEMS */
.trend-item{display:flex;align-items:center;padding:9px 16px;border-bottom:1px solid var(--border);}
.trend-item:last-child{border-bottom:none;}
.trend-delta{font-family:var(--mono);font-size:12px;font-weight:600;width:58px;flex-shrink:0;}
.trend-info{flex:1;min-width:0;}
.trend-name{font-size:12px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.trend-sla{font-size:10px;color:var(--text2);margin-top:2px;}

/* MODAL */
.modal-backdrop{display:none;position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:200;backdrop-filter:blur(4px);align-items:center;justify-content:center;}
.modal-backdrop.open{display:flex;}
.modal{background:var(--surface);border:1px solid var(--border);border-radius:18px;padding:24px;width:90vw;max-width:720px;max-height:88vh;overflow-y:auto;}
.modal-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:16px;}
.modal-title{font-size:16px;font-weight:700;}
.modal-sub{font-size:12px;color:var(--text2);margin-top:3px;}
.modal-close{background:var(--surface2);border:1px solid var(--border);color:var(--text);border-radius:8px;padding:5px 12px;cursor:pointer;font-family:var(--font);font-size:12px;}
.modal-kpis{display:grid;grid-template-columns:repeat(auto-fit,minmax(110px,1fr));gap:10px;margin-bottom:20px;}
.modal-kpi{background:var(--surface2);border-radius:10px;padding:12px;}
.modal-kpi-label{font-size:10px;color:var(--text2);text-transform:uppercase;letter-spacing:.5px;margin-bottom:5px;}
.modal-kpi-val{font-size:20px;font-weight:700;font-family:var(--mono);}

@media(max-width:768px){.header{padding:14px;}.content{padding:14px;}.filter-bar{padding:10px 14px;}}
</style>
</head>
<body>

<div class="header">
  <div class="logo">🛵</div>
  <div>
    <h1>iFood Operacional — Drogarias Venancio</h1>
    <p id="header-sub">Carregando…</p>
  </div>
</div>

<div class="filter-bar">
  <span class="filter-label">Regional</span>
  <div class="filter-chip active" onclick="setRegional('TODOS',this)">Todos</div>
  <div id="regional-chips" style="display:flex;flex-wrap:wrap;gap:10px;"></div>
</div>

<div class="nav-tabs">
  <div class="tab active" onclick="showSection('overview',this)">📊 Visão Geral</div>
  <div class="tab" onclick="showSection('stores',this)">🏪 Ranking Lojas</div>
  <div class="tab" onclick="showSection('alerts',this)">🚨 Alertas</div>
  <div class="tab" onclick="showSection('trends',this)">📈 Evolução</div>
</div>

<div class="content">

<!-- OVERVIEW -->
<div class="section active" id="section-overview">
  <div class="kpi-grid" id="kpi-grid"></div>
  <div class="bench-wrap">
    <div class="sec-header"><h2>📅 Benchmark da Rede por Semana</h2><div class="chip" id="bench-regional-label">Todas as lojas</div></div>
    <div class="bench-chart" id="bench-chart"></div>
  </div>
  <div class="sec-divider"></div>
  <div class="top-grid">
    <div class="top-card">
      <div class="top-card-header"><span class="icon">🏆</span><div><h3>Top 5 Melhores SLA Sep.</h3><div class="subtitle">Última semana</div></div></div>
      <div id="top-best-sla"></div>
    </div>
    <div class="top-card">
      <div class="top-card-header"><span class="icon">⚠️</span><div><h3>Top 5 Piores SLA Sep.</h3><div class="subtitle">Última semana</div></div></div>
      <div id="top-worst-sla"></div>
    </div>
    <div class="top-card">
      <div class="top-card-header"><span class="icon">📦</span><div><h3>Maior Ruptura</h3><div class="subtitle">Última semana</div></div></div>
      <div id="top-ruptura"></div>
    </div>
    <div class="top-card">
      <div class="top-card-header"><span class="icon">❌</span><div><h3>Maior Cancelamento</h3><div class="subtitle">Última semana</div></div></div>
      <div id="top-cancel"></div>
    </div>
  </div>
</div>

<!-- STORES -->
<div class="section" id="section-stores">
  <div class="table-wrap">
    <div class="table-controls">
      <input class="search-box" placeholder="🔍 Buscar loja…" id="store-search" oninput="renderStoresTable()">
      <button class="sort-btn active" id="sort-pedidos" onclick="setSort('pedidos',this)">↓ Volume</button>
      <button class="sort-btn" id="sort-sla" onclick="setSort('sla',this)">SLA Sep. ↑</button>
      <button class="sort-btn" id="sort-score" onclick="setSort('score',this)">Score Risco ↓</button>
      <button class="sort-btn" id="sort-cancel" onclick="setSort('cancel',this)">Cancelamento ↓</button>
      <button class="sort-btn" id="sort-tempo" onclick="setSort('tempo_inicio',this)">Tempo Início ↓</button>
    </div>
    <div style="overflow-x:auto;">
      <table>
        <thead>
          <tr>
            <th>#</th><th>Loja</th><th>Regional</th><th>Pedidos</th>
            <th>SLA Sep. ↑</th><th>NSU &lt;5min ↑</th><th>Tempo Início (min) ↓</th>
            <th>Ruptura</th><th>Cancelamento</th><th>Atraso Crítico</th>
            <th>Score Risco</th><th>Trend SLA Sep.</th>
          </tr>
        </thead>
        <tbody id="stores-tbody"></tbody>
      </table>
    </div>
    <div class="pagination">
      <div class="page-info" id="page-info"></div>
      <div class="page-btns">
        <button class="page-btn" id="btn-prev" onclick="changePage(-1)">← Ant.</button>
        <button class="page-btn" id="btn-next" onclick="changePage(1)">Próx. →</button>
      </div>
    </div>
  </div>
</div>

<!-- ALERTS -->
<div class="section" id="section-alerts">
  <div class="top-grid">
    <div class="top-card">
      <div class="top-card-header" style="border-left:3px solid var(--red)"><span class="icon">🛵</span><div><h3>Pior NSU (motoboy &gt;5min na loja)</h3><div class="subtitle">Fila interna — separação lenta</div></div></div>
      <div id="alert-nsu"></div>
    </div>
    <div class="top-card">
      <div class="top-card-header" style="border-left:3px solid #a78bfa"><span class="icon">⏱️</span><div><h3>Maior Tempo de Início</h3><div class="subtitle">Demora para começar a separar (min)</div></div></div>
      <div id="alert-tempo"></div>
    </div>
    <div class="top-card">
      <div class="top-card-header" style="border-left:3px solid var(--yellow)"><span class="icon">⏰</span><div><h3>Maior Atraso Crítico</h3><div class="subtitle">Pedidos muito atrasados</div></div></div>
      <div id="alert-atraso"></div>
    </div>
    <div class="top-card">
      <div class="top-card-header" style="border-left:3px solid var(--accent)"><span class="icon">❌</span><div><h3>Maior Cancelamento</h3><div class="subtitle">Última semana</div></div></div>
      <div id="alert-cancel"></div>
    </div>
  </div>

  <div class="top-grid">
    <div class="top-card">
      <div class="top-card-header" style="border-left:3px solid var(--red)"><span class="icon">📉</span><div><h3>Lojas que Pioraram</h3><div class="subtitle">Delta SLA Sep.: semana 1 → última semana</div></div></div>
      <div id="trend-piorou"></div>
    </div>
    <div class="top-card">
      <div class="top-card-header" style="border-left:3px solid var(--green)"><span class="icon">📈</span><div><h3>Lojas que Melhoraram</h3><div class="subtitle">Delta SLA Sep.: semana 1 → última semana</div></div></div>
      <div id="trend-melhorou"></div>
    </div>
  </div>

  <div class="sec-header"><h2>🎯 Lojas Críticas — Ação Imediata</h2><div class="chip" id="critical-count"></div></div>
  <div class="table-wrap">
    <div style="overflow-x:auto;">
      <table>
        <thead><tr><th>Loja</th><th>Regional</th><th>Pedidos</th><th>SLA Sep. ↑</th><th>NSU ↑</th><th>T.Início ↓</th><th>Cancel</th><th>Ruptura</th><th>Score</th><th>Problemas</th></tr></thead>
        <tbody id="critical-tbody"></tbody>
      </table>
    </div>
  </div>
</div>

<!-- TRENDS -->
<div class="section" id="section-trends">
  <div class="sec-header"><h2>📈 Evolução Semanal por Loja</h2><div class="chip">Top 24 por volume · clique para detalhe</div></div>
  <div class="top-grid" id="trend-charts"></div>
</div>

</div><!-- /content -->

<!-- MODAL -->
<div class="modal-backdrop" id="modal-backdrop" onclick="closeModal(event)">
  <div class="modal">
    <div class="modal-header">
      <div><div class="modal-title" id="modal-title"></div><div class="modal-sub" id="modal-sub"></div></div>
      <button class="modal-close" onclick="closeModalDirect()">✕ Fechar</button>
    </div>
    <div class="modal-kpis" id="modal-kpis"></div>
    <div id="modal-charts"></div>
  </div>
</div>

