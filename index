const REGIONAL_COLORS = {
  'Daygine':'#f97316','Edinaldo':'#06b6d4','Juan':'#8b5cf6','Luciana':'#ec4899',
  'Marcio':'#14b8a6','Nathalia':'#f59e0b','Raphaela':'#3b82f6','Rodrigo':'#22c55e',
