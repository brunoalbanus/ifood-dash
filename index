  'Sem Regional':'#4a5068'
};
const PAGE_SIZE = 20;

// ── STATE ─────────────────────────────────────────────────────────────────
let activeRegional = 'TODOS';
let currentSort = 'pedidos';
let currentPage = 1;
let sortAsc = false;

// ── HELPERS ───────────────────────────────────────────────────────────────
function pctColor(v, goodHigh=true) {
  if (v == null) return 'var(--text3)';
  const n = parseFloat(v);
  if (goodHigh) {
    if (n >= 75) return 'var(--green)';
    if (n >= 60) return 'var(--yellow)';
    return 'var(--red)';
  } else {
    if (n <= 5) return 'var(--green)';
    if (n <= 10) return 'var(--yellow)';
    return 'var(--red)';
  }
}

function tempoColor(v) {
  if (v == null) return 'var(--text3)';
  if (v <= 4) return 'var(--green)';
  if (v <= 7) return 'var(--yellow)';
  return 'var(--red)';
}

function fmtPct(v, goodHigh=true) {
  if (v == null) return '<span style="color:var(--text3)">—</span>';
  return `<span class="pct" style="color:${pctColor(v,goodHigh)}">${parseFloat(v).toFixed(1)}%</span>`;
}

function fmtTempo(v) {
  if (v == null) return '<span style="color:var(--text3)">—</span>';
  return `<span class="pct" style="color:${tempoColor(v)}">${parseFloat(v).toFixed(1)}m</span>`;
}

function barEl(v, max=100, color='var(--blue)') {
  if (v == null) return '';
  const w = Math.min(80, (v/max)*80);
  return `<div class="bar" style="width:${w}px;background:${color}"></div>`;
}

function sparkline(series, color) {
  const valid = series.filter(x => x != null);
  if (valid.length < 2) return '<span style="color:var(--text3);font-size:10px">—</span>';
  const min = Math.min(...valid), max = Math.max(...valid), range = max-min||1;
  return `<div class="spark">${series.map(v => {
    if (v == null) return `<div class="spark-bar" style="height:3px;background:var(--border)"></div>`;
    const h = 3 + ((v-min)/range)*18;
    return `<div class="spark-bar" style="height:${h}px;background:${color}"></div>`;
  }).join('')}</div>`;
}

function scoreCls(s) {
  if (s >= 30) return 'score-high';
  if (s >= 20) return 'score-med';
  return 'score-low';
}

function regionalBadge(r) {
  const c = REGIONAL_COLORS[r] || '#4a5068';
  return `<span class="td-regional" style="background:${c}22;color:${c}">${r}</span>`;
}

function filteredStores() {
  const q = document.getElementById('store-search')?.value.toLowerCase() || '';
  return DATA.stores.filter(s =>
    (activeRegional === 'TODOS' || s.regional === activeRegional) &&
    (s.nome.toLowerCase().includes(q) || s.cidade.toLowerCase().includes(q) || s.regional.toLowerCase().includes(q))
  );
}

function sortedStores() {
  const list = filteredStores();
  const k = currentSort;
  list.sort((a, b) => {
    const av = a[k] ?? (sortAsc ? Infinity : -Infinity);
    const bv = b[k] ?? (sortAsc ? Infinity : -Infinity);
    return sortAsc ? av - bv : bv - av;
  });
  return list;
}

// ── REGIONAL FILTER ────────────────────────────────────────────────────────
function buildRegionalChips() {
  const el = document.getElementById('regional-chips');
  el.innerHTML = DATA.regionais.map(r => {
    const c = REGIONAL_COLORS[r]||'#4a5068';
    return `<div class="filter-chip" style="border-color:${c}33" onclick="setRegional('${r}',this)" data-r="${r}">${r}</div>`;
  }).join('');
}

function setRegional(r, el) {
  activeRegional = r;
  currentPage = 1;
  document.querySelectorAll('.filter-chip').forEach(c => {
    c.classList.remove('active');
    c.style.background = '';
    c.style.color = '';
  });
  if (el) {
    el.classList.add('active');
    if (r !== 'TODOS') {
      const c = REGIONAL_COLORS[r]||'var(--blue)';
      el.style.background = c;
      el.style.color = 'white';
      el.style.borderColor = c;
    }
  }
  document.getElementById('bench-regional-label').textContent = r === 'TODOS' ? 'Todas as lojas' : `Regional: ${r}`;
  renderAll();
}

// ── SORT ───────────────────────────────────────────────────────────────────
function setSort(key, btn) {
  if (currentSort === key) { sortAsc = !sortAsc; }
  else { currentSort = key; sortAsc = ['sla','nsu'].includes(key); }
  currentPage = 1;
  document.querySelectorAll('.sort-btn').forEach(b => b.classList.remove('active'));
  if (btn) btn.classList.add('active');
  renderStoresTable();
}

// ── RENDER ALL ─────────────────────────────────────────────────────────────
function renderAll() {
  renderKPIs();
  renderBench();
  renderTopLists();
  renderStoresTable();
  renderAlerts();
  renderTrends();
}

// ── KPIs ───────────────────────────────────────────────────────────────────
function renderKPIs() {
  const stores = filteredStores();
  const semNums = [...new Set(DATA.stores.map(s => s.sla_series.length))];
  const nWeeks = DATA.semanas.length;

  // compute averages per week from filtered stores
  function weekAvg(series_key, week_idx) {
    const vals = stores.map(s => (s[series_key]||[])[week_idx]).filter(v => v != null);
    if (!vals.length) return null;
    return vals.reduce((a,b)=>a+b,0)/vals.length;
  }

  const lastIdx = nWeeks - 1;
  const prevIdx = nWeeks - 2;

  const metrics = [
    {key:'sla_series', label:'SLA Separação', sub:'% pedidos separados no prazo', cls:'sla', color:'var(--blue)', goodHigh:true, fmt:v=>`${v.toFixed(1)}%`},
    {key:'nsu_series', label:'NSU <5min', sub:'motoboy ≤5min na loja', cls:'nsu', color:'var(--green)', goodHigh:true, fmt:v=>`${v.toFixed(1)}%`},
    {key:'tempo_inicio_series', label:'Tempo Início', sub:'min para começar separar', cls:'tempo', color:'#a78bfa', goodHigh:false, fmt:v=>`${v.toFixed(1)}m`},
    {key:'ruptura_series', label:'Ruptura', sub:'pedidos rupturados', cls:'ruptura', color:'var(--yellow)', goodHigh:false, fmt:v=>`${v.toFixed(1)}%`},
    {key:'cancel_series', label:'Cancelamento', sub:'pedidos cancelados', cls:'cancel', color:'var(--accent)', goodHigh:false, fmt:v=>`${v.toFixed(1)}%`},
    {key:'atraso_series', label:'Atraso Crítico', sub:'pedidos muito atrasados', cls:'atraso', color:'var(--accent2)', goodHigh:false, fmt:v=>`${v.toFixed(1)}%`},
  ];

  document.getElementById('kpi-grid').innerHTML = metrics.map(m => {
    const last = weekAvg(m.key, lastIdx);
    const prev = weekAvg(m.key, prevIdx);
    if (last == null) return '';
    const d = prev != null ? last - prev : null;
    const positive = d != null ? (m.goodHigh ? d > 0 : d < 0) : null;
    const dStr = d != null ? `<div class="kpi-delta ${positive?'up':'down'}">${d>0?'+':''}${d.toFixed(1)}${m.key.includes('tempo')?'m':'pp'} vs semana anterior</div>` : '';
    return `<div class="kpi ${m.cls}">
      <div class="kpi-label">${m.label}</div>
      <div class="kpi-value" style="color:${m.color}">${m.fmt(last)}</div>
      <div class="kpi-sub">${m.sub}</div>
      ${dStr}
    </div>`;
  }).join('') + `<div class="kpi pedidos">
    <div class="kpi-label">Lojas no Filtro</div>
    <div class="kpi-value" style="color:#94a3b8">${stores.length}</div>
    <div class="kpi-sub">de ${DATA.stores.length} total</div>
  </div>`;
}

// ── BENCH ──────────────────────────────────────────────────────────────────
function renderBench() {
  const stores = filteredStores();
  const nWeeks = DATA.semanas.length;
  const colors = {SLA:'var(--blue)',NSU:'var(--green)','T.Início':'#a78bfa',Ruptura:'var(--yellow)',Cancelamento:'var(--accent)','Atraso':'var(--accent2)'};

  function weekAvg(series_key, week_idx) {
    const vals = stores.map(s => (s[series_key]||[])[week_idx]).filter(v => v != null);
    return vals.length ? vals.reduce((a,b)=>a+b,0)/vals.length : null;
  }

  document.getElementById('bench-chart').innerHTML = DATA.semanas.map((label, i) => {
    const sla = weekAvg('sla_series', i);
    const nsu = weekAvg('nsu_series', i);
    const ti = weekAvg('tempo_inicio_series', i);
    const rup = weekAvg('ruptura_series', i);
    const can = weekAvg('cancel_series', i);
    const atr = weekAvg('atraso_series', i);
    const ped = stores.reduce((sum, s) => sum + ((s.sla_series||[])[i] != null ? (s.pedidos/nWeeks) : 0), 0);
    const rows = [
      ['SLA',sla,'var(--blue)',v=>`${v.toFixed(1)}%`],
      ['NSU',nsu,'var(--green)',v=>`${v.toFixed(1)}%`],
      ['T.Início',ti,'#a78bfa',v=>`${v.toFixed(1)}m`],
      ['Ruptura',rup,'var(--yellow)',v=>`${v.toFixed(1)}%`],
      ['Cancelamento',can,'var(--accent)',v=>`${v.toFixed(1)}%`],
      ['Atraso',atr,'var(--accent2)',v=>`${v.toFixed(1)}%`],
    ];
    return `<div class="bench-week">
      <div class="bench-week-label">📅 ${label}</div>
      ${rows.map(([n,v,c,f]) => v != null ? `<div class="bench-metric"><span class="bench-metric-name">${n}</span><span class="bench-metric-val" style="color:${c}">${f(v)}</span></div>` : '').join('')}
    </div>`;
  }).join('');
}

// ── TOP LISTS ──────────────────────────────────────────────────────────────
function renderTopLists() {
  const rankC = ['#ffd60a','#c0c0c0','#cd7f32','var(--text3)','var(--text3)'];
  const stores = filteredStores();
  const nWeeks = DATA.semanas.length;

  function getLastVal(s, key) {
    const series = s[key] || [];
    const valid = series.filter(v => v != null);
    return valid.length ? valid[valid.length-1] : null;
  }

  function topItem(s, rank, val, color) {
    return `<div class="top-item">
      <div class="top-rank" style="background:${rankC[rank]}22;color:${rankC[rank]}">${rank+1}</div>
      <div class="top-store">
        <div class="top-store-name">${s.nome}</div>
        <div class="top-store-city">${s.cidade} · ${s.regional}</div>
      </div>
      <div class="top-val" style="color:${color}">${val}</div>
    </div>`;
  }

  const withLast = (key) => stores.map(s => ({...s, _v: getLastVal(s, key)})).filter(s => s._v != null);

  const bestSLA = withLast('sla_series').sort((a,b)=>b._v-a._v).slice(0,5);
  const worstSLA = withLast('sla_series').sort((a,b)=>a._v-b._v).slice(0,5);
  const topRup = withLast('ruptura_series').sort((a,b)=>b._v-a._v).slice(0,5);
  const topCan = withLast('cancel_series').sort((a,b)=>b._v-a._v).slice(0,5);

  document.getElementById('top-best-sla').innerHTML = bestSLA.map((s,i)=>topItem(s,i,`${s._v.toFixed(1)}%`,'var(--green)')).join('');
  document.getElementById('top-worst-sla').innerHTML = worstSLA.map((s,i)=>topItem(s,i,`${s._v.toFixed(1)}%`,'var(--red)')).join('');
  document.getElementById('top-ruptura').innerHTML = topRup.map((s,i)=>topItem(s,i,`${s._v.toFixed(1)}%`,'var(--yellow)')).join('');
  document.getElementById('top-cancel').innerHTML = topCan.map((s,i)=>topItem(s,i,`${s._v.toFixed(1)}%`,'var(--accent)')).join('');
}

// ── STORES TABLE ───────────────────────────────────────────────────────────
function renderStoresTable() {
  const list = sortedStores();
  const total = Math.ceil(list.length / PAGE_SIZE);
  if (currentPage > total) currentPage = Math.max(1, total);
  const start = (currentPage-1)*PAGE_SIZE;
  const slice = list.slice(start, start+PAGE_SIZE);

  document.getElementById('page-info').textContent = `${start+1}–${Math.min(start+PAGE_SIZE,list.length)} de ${list.length} lojas`;
  document.getElementById('btn-prev').disabled = currentPage <= 1;
  document.getElementById('btn-next').disabled = currentPage >= total;

  document.getElementById('stores-tbody').innerHTML = slice.map((s,i) => {
    const tCls = s.trend==='↑'?'trend-up':s.trend==='↓'?'trend-down':'trend-flat';
    return `<tr onclick="openModal('${s.nome.replace(/'/g,"\\'")}')">
      <td style="color:var(--text3);font-size:11px">${start+i+1}</td>
      <td class="td-store">${s.nome}<small>${s.cidade}</small></td>
      <td>${regionalBadge(s.regional)}</td>
      <td style="font-family:var(--mono)">${s.pedidos.toLocaleString('pt-BR')}</td>
      <td><div class="bar-cell">${barEl(s.sla,100,'var(--blue)')}${fmtPct(s.sla,true)}</div></td>
      <td><div class="bar-cell">${barEl(s.nsu,100,'var(--green)')}${fmtPct(s.nsu,true)}</div></td>
      <td>${fmtTempo(s.tempo_inicio)}</td>
      <td>${fmtPct(s.ruptura,false)}</td>
      <td>${fmtPct(s.cancel,false)}</td>
      <td>${fmtPct(s.atraso,false)}</td>
      <td><span class="score-badge ${scoreCls(s.score)}">${s.score!=null?s.score.toFixed(0):'—'}</span></td>
      <td>${sparkline(s.sla_series,'var(--blue)')} <span class="${tCls}">${s.trend}</span></td>
    </tr>`;
  }).join('') || '<tr><td colspan="12" style="text-align:center;padding:32px;color:var(--text3)">Nenhuma loja encontrada</td></tr>';
}

function changePage(dir) {
  const list = sortedStores();
  const total = Math.ceil(list.length/PAGE_SIZE);
  currentPage = Math.max(1, Math.min(total, currentPage+dir));
  renderStoresTable();
}

// ── ALERTS ─────────────────────────────────────────────────────────────────
function renderAlerts() {
  const stores = filteredStores();
  const rankC = ['#ff4757','#ff6b6b','#ff8787','#ffa3a3','#ffbfbf','#ffd5d5','#ffe0e0','#ffebeb'];

  function getLastVal(s, key) {
    const series = s[key]||[];
    const valid = series.filter(v=>v!=null);
    return valid.length ? valid[valid.length-1] : null;
  }

  function alertItem(s, val, color, extra='') {
    return `<div class="top-item">
      <div class="top-store">
        <div class="top-store-name">${s.nome}</div>
        <div class="top-store-city">${s.cidade} · ${regionalBadge(s.regional)} ${extra}</div>
      </div>
      <div class="top-val" style="color:${color}">${val}</div>
    </div>`;
  }

  const worstNSU = stores.map(s=>({...s,_v:getLastVal(s,'nsu_series')})).filter(s=>s._v!=null).sort((a,b)=>a._v-b._v).slice(0,8);
  const worstTempo = stores.map(s=>({...s,_v:getLastVal(s,'tempo_inicio_series')})).filter(s=>s._v!=null).sort((a,b)=>b._v-a._v).slice(0,8);
  const worstAtraso = stores.map(s=>({...s,_v:getLastVal(s,'atraso_series')})).filter(s=>s._v!=null).sort((a,b)=>b._v-a._v).slice(0,8);
  const worstCancel = stores.map(s=>({...s,_v:getLastVal(s,'cancel_series')})).filter(s=>s._v!=null).sort((a,b)=>b._v-a._v).slice(0,8);

  document.getElementById('alert-nsu').innerHTML = worstNSU.map(s=>alertItem(s,`${s._v.toFixed(1)}%`,'var(--red)',`· SLA: ${getLastVal(s,'sla_series')?.toFixed(1)||'—'}%`)).join('');
  document.getElementById('alert-tempo').innerHTML = worstTempo.map(s=>alertItem(s,`${s._v.toFixed(1)}m`,'#a78bfa')).join('');
  document.getElementById('alert-atraso').innerHTML = worstAtraso.map(s=>alertItem(s,`${s._v.toFixed(1)}%`,'var(--accent2)')).join('');
  document.getElementById('alert-cancel').innerHTML = worstCancel.map(s=>alertItem(s,`${s._v.toFixed(1)}%`,'var(--accent)')).join('');

  // Trend
  const withDelta = stores.filter(s => {
    const v0 = (s.sla_series||[]).find(v=>v!=null);
    const vn = [...(s.sla_series||[])].reverse().find(v=>v!=null);
    return v0!=null && vn!=null;
  }).map(s => {
    const v0 = s.sla_series.find(v=>v!=null);
    const vn = [...s.sla_series].reverse().find(v=>v!=null);
    return {...s, _s1: v0, _sn: vn, _d: vn-v0};
  });

  const piorou = [...withDelta].sort((a,b)=>a._d-b._d).slice(0,8);
  const melhorou = [...withDelta].sort((a,b)=>b._d-a._d).slice(0,8);

  document.getElementById('trend-piorou').innerHTML = piorou.map(s=>`
    <div class="trend-item">
      <div class="trend-delta" style="color:var(--red)">${s._d.toFixed(1)}pp</div>
      <div class="trend-info">
        <div class="trend-name">${s.nome}</div>
        <div class="trend-sla">${s._s1.toFixed(1)}% → ${s._sn.toFixed(1)}% · ${s.regional}</div>
      </div>
    </div>`).join('');

  document.getElementById('trend-melhorou').innerHTML = melhorou.map(s=>`
    <div class="trend-item">
      <div class="trend-delta" style="color:var(--green)">+${s._d.toFixed(1)}pp</div>
      <div class="trend-info">
        <div class="trend-name">${s.nome}</div>
        <div class="trend-sla">${s._s1.toFixed(1)}% → ${s._sn.toFixed(1)}% · ${s.regional}</div>
      </div>
    </div>`).join('');

  // Critical table
  const critical = stores.filter(s => (s.score||0) >= 28).sort((a,b)=>(b.score||0)-(a.score||0));
  document.getElementById('critical-count').textContent = `${critical.length} lojas`;
  document.getElementById('critical-tbody').innerHTML = critical.map(s => {
    const issues = [];
    if ((s.sla||100) < 60) issues.push('⚠️ SLA baixo');
    if ((s.cancel||0) > 12) issues.push('❌ Cancel alto');
    if ((s.ruptura||0) > 12) issues.push('📦 Ruptura alta');
    if ((s.nsu||100) < 55) issues.push('🛵 NSU ruim');
    if ((s.atraso||0) > 12) issues.push('⏰ Atraso');
    if ((s.tempo_inicio||0) > 7) issues.push('⏱️ T.Início lento');
    return `<tr onclick="openModal('${s.nome.replace(/'/g,"\\'")}')">
      <td class="td-store">${s.nome}<small>${s.cidade}</small></td>
      <td>${regionalBadge(s.regional)}</td>
      <td style="font-family:var(--mono)">${s.pedidos}</td>
      <td>${fmtPct(s.sla,true)}</td>
      <td>${fmtPct(s.nsu,true)}</td>
      <td>${fmtTempo(s.tempo_inicio)}</td>
      <td>${fmtPct(s.cancel,false)}</td>
      <td>${fmtPct(s.ruptura,false)}</td>
      <td><span class="score-badge ${scoreCls(s.score)}">${s.score?.toFixed(0)||'—'}</span></td>
      <td style="font-size:10px">${issues.join(' ')}</td>
    </tr>`;
  }).join('');
}

// ── TRENDS ─────────────────────────────────────────────────────────────────
function renderTrends() {
  const stores = filteredStores().slice(0,24);
  const n = DATA.semanas.length;
  document.getElementById('trend-charts').innerHTML = stores.map(s => {
    const series = s.sla_series.filter(v=>v!=null);
    if (!series.length) return '';
    const min = 0, max = 100;
    const w = 260, h = 55;
    const pts = DATA.semanas.map((_,i) => {
      const v = s.sla_series[i];
      if (v==null) return null;
      const x = n>1 ? (i/(n-1))*w : w/2;
      const y = h - ((v-min)/(max-min))*(h-10)-5;
      return {x,y,v};
    }).filter(Boolean);
    const poly = pts.length>=2 ? `<polyline points="${pts.map(p=>`${p.x},${p.y}`).join(' ')}" fill="none" stroke="var(--blue)" stroke-width="2" stroke-linecap="round"/>` : '';
    const dots = pts.map(p=>`<circle cx="${p.x}" cy="${p.y}" r="3" fill="var(--blue)" stroke="var(--surface)" stroke-width="1.5"/><text x="${p.x}" y="${p.y-7}" font-size="8" fill="var(--text2)" text-anchor="middle">${p.v.toFixed(0)}</text>`).join('');
    const trendC = s.trend==='↑'?'var(--green)':s.trend==='↓'?'var(--red)':'var(--text2)';
    const rc = REGIONAL_COLORS[s.regional]||'#4a5068';
    return `<div class="top-card" onclick="openModal('${s.nome.replace(/'/g,"\\'")}')">
      <div class="top-card-header">
        <span class="icon">🏪</span>
        <div style="min-width:0;flex:1">
          <h3 style="font-size:11px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${s.nome}</h3>
          <div class="subtitle">${s.cidade} · <span style="color:${rc};font-weight:600">${s.regional}</span> · SLA Sep. ${s.sla}% <span style="color:${trendC}">${s.trend}</span></div>
        </div>
      </div>
      <div style="padding:14px 18px">
        <div style="font-size:9px;color:var(--text3);margin-bottom:6px">SLA Separação % por semana</div>
        <svg viewBox="0 0 ${w} ${h}" style="width:100%;height:${h}px;overflow:visible">${poly}${dots}</svg>
        <div style="display:flex;justify-content:space-between;margin-top:3px">
          ${DATA.semanas.map(s=>`<span style="font-size:8px;color:var(--text3)">${s.split(' ')[0]}</span>`).join('')}
        </div>
        <div style="display:flex;gap:12px;margin-top:10px;flex-wrap:wrap">
          <span style="font-size:10px">🛵 NSU <b style="color:var(--green)">${s.nsu??'—'}%</b></span>
          <span style="font-size:10px">⏱️ T.In <b style="color:#a78bfa">${s.tempo_inicio??'—'}m</b></span>
          <span style="font-size:10px">❌ Can <b style="color:var(--accent)">${s.cancel??'—'}%</b></span>
          <span style="font-size:10px">📦 Rup <b style="color:var(--yellow)">${s.ruptura??'—'}%</b></span>
        </div>
      </div>
    </div>`;
  }).join('');
}

// ── MODAL ──────────────────────────────────────────────────────────────────
function openModal(nome) {
  const s = DATA.stores.find(x=>x.nome===nome);
  if (!s) return;
  const rc = REGIONAL_COLORS[s.regional]||'#4a5068';
  document.getElementById('modal-title').textContent = s.nome;
  document.getElementById('modal-sub').innerHTML = `${s.cidade} · <span style="color:${rc};font-weight:600">${s.regional}</span> · ${s.pedidos.toLocaleString('pt-BR')} pedidos`;

  const kpis = [
    {l:'SLA Separação', v:s.sla+'%', c:'var(--blue)'},
    {l:'NSU <5min', v:s.nsu+'%', c:'var(--green)'},
    {l:'T. Início', v:(s.tempo_inicio??'—')+(s.tempo_inicio?'m':''), c:'#a78bfa'},
    {l:'Ruptura', v:s.ruptura+'%', c:'var(--yellow)'},
    {l:'Cancelamento', v:s.cancel+'%', c:'var(--accent)'},
    {l:'Atraso Crítico', v:s.atraso+'%', c:'var(--accent2)'},
    {l:'Score Risco', v:s.score?.toFixed(0)||'—', c:s.score>=30?'var(--red)':s.score>=20?'var(--yellow)':'var(--green)'},
  ];
  document.getElementById('modal-kpis').innerHTML = kpis.map(k=>`
    <div class="modal-kpi">
      <div class="modal-kpi-label">${k.l}</div>
      <div class="modal-kpi-val" style="color:${k.c}">${k.v}</div>
    </div>`).join('');

  const charts = [
    {key:'sla_series', label:'SLA Separação (%)', color:'#4a90f5', goodHigh:true},
    {key:'nsu_series', label:'NSU <5min (%)', color:'#00d9a0', goodHigh:true},
    {key:'tempo_inicio_series', label:'Tempo Início (min)', color:'#a78bfa', goodHigh:false},
    {key:'cancel_series', label:'Cancelamento (%)', color:'#ff3e6c', goodHigh:false},
    {key:'ruptura_series', label:'Ruptura (%)', color:'#ffd60a', goodHigh:false},
  ];

  document.getElementById('modal-charts').innerHTML = charts.map(m => {
    const series = s[m.key]||[];
    const valid = series.filter(v=>v!=null);
    if (!valid.length) return '';
    const min=0, max=m.key.includes('tempo')?Math.max(15,...valid):100;
    const w=380, h=65, n=DATA.semanas.length;
    const pts = DATA.semanas.map((_,i) => {
      const v=series[i]; if(v==null) return null;
      const x=n>1?(i/(n-1))*w:w/2;
      const y=h-((v-min)/(max-min))*(h-14)-7;
      return {x,y,v};
    }).filter(Boolean);
    const poly = pts.length>=2?`<polyline points="${pts.map(p=>`${p.x},${p.y}`).join(' ')}" fill="none" stroke="${m.color}" stroke-width="2.5" stroke-linecap="round"/>`:''
    const dots = pts.map(p=>`<circle cx="${p.x}" cy="${p.y}" r="4" fill="${m.color}" stroke="var(--surface)" stroke-width="2"/><text x="${p.x}" y="${p.y-9}" font-size="9" fill="${m.color}" text-anchor="middle">${p.v.toFixed(1)}</text>`).join('');
    return `<div style="margin-bottom:18px">
      <div style="font-size:11px;color:var(--text2);margin-bottom:6px">${m.label}</div>
      <svg viewBox="0 0 ${w} ${h}" style="width:100%;height:${h}px;overflow:visible">${poly}${dots}</svg>
      <div style="display:flex;justify-content:space-between;margin-top:2px">
        ${DATA.semanas.map(s=>`<span style="font-size:9px;color:var(--text3)">${s}</span>`).join('')}
      </div>
    </div>`;
  }).join('');

  document.getElementById('modal-backdrop').classList.add('open');
}

function closeModal(e) { if(e.target===document.getElementById('modal-backdrop')) closeModalDirect(); }
function closeModalDirect() { document.getElementById('modal-backdrop').classList.remove('open'); }

// ── NAV ────────────────────────────────────────────────────────────────────
function showSection(id, el) {
  document.querySelectorAll('.section').forEach(s=>s.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  document.getElementById('section-'+id).classList.add('active');
  if(el) el.classList.add('active');
}

// ── INIT ───────────────────────────────────────────────────────────────────
function init() {
  document.getElementById('header-sub').textContent = `${DATA.stores.length} lojas · ${DATA.semanas.length} semanas · última: ${DATA.last_week_label}`;
  buildRegionalChips();
  renderAll();
}

init();
</script>
</body>
